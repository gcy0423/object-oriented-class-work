{
  "name": "edumind-agent",
  "version": "1.0.0",
  "description": "EduMind Agent 智能学习计划与协作系统，面向《面向对象技术与方法》结课设计。",
  "type": "module",
  "scripts": {
    "start": "node server/src/main.js",
    "dev": "node server/src/main.js",
    "start:mock": "set LLM_PROVIDER=mock&& node server/src/main.js",
    "start:gateway": "node services/gateway-service/src/main.js",
    "start:identity": "node services/identity-service/src/main.js",
    "start:learning": "node services/learning-service/src/main.js",
    "start:assessment": "node services/assessment-service/src/main.js",
    "start:ai": "node services/ai-service/src/main.js",
    "start:collaboration": "node services/collaboration-service/src/main.js",
    "start:analytics": "node services/analytics-service/src/main.js",
    "start:services": "node scripts/startServices.mjs",
    "start:services:mock": "node scripts/startServices.mjs --mock",
    "test": "node --test test/kernel.test.mjs test/client.test.mjs",
    "test:services": "node --test test/services.test.mjs",
    "test:lmstudio": "node scripts/verifyLmStudio.mjs",
    "linecount": "node scripts/linecount.mjs"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
